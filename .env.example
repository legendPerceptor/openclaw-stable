# ==================== Akali OpenClaw 配置 ====================
# 所有 NAS 特有路径都通过环境变量配置

# ==================== 端口配置 ====================
OPENCLAW_PORT=18789
XRAY_PORT=8117
QDRANT_PORT=6336
QDRANT_GRPC_PORT=6337

# ==================== 路径配置 ====================
# OpenClaw 工作目录（挂载到容器）
OPENCLAW_WORKSPACE=/volume1/shared-shanghai/openclaw-workhome/1panel-claw

# SSH 密钥路径（用于 Git 操作）
SSH_KEY_PATH=/home/briannas/.ssh

# Xray 配置文件（包含代理服务器信息）
XRAY_CONFIG_PATH=/volume1/shared-shanghai/openclaw-workhome/1panel-claw/workspace/openclaw-stable/xray/config.json

# Qdrant 数据存储路径
QDRANT_STORAGE_PATH=/volume1/shared-shanghai/openclaw-workhome/qdrant-backup/

# ==================== 代理配置 ====================
# HTTP/HTTPS 代理（使用内置 akali-xray）
HTTP_PROXY=http://akali-xray:1087
HTTPS_PROXY=http://akali-xray:1087

# 不走代理的域名（直连）
# 飞书、GLM、MiniMax、Brave Search 直连，其他走代理
NO_PROXY=localhost,127.0.0.1,*.feishu.cn,*.larksuite.com,*.zhipuai.cn,bigmodel.cn,open.bigmodel.cn,api.minimaxi.com,api.search.brave.com
